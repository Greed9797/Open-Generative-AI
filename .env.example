MINIMAX_API_KEY=
GEMINI_API_KEY=
VERTEX_AI_API_KEY=
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1

# Supabase API key vault (same Supabase project can be reused from the old CreativeOS prototype)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
REPLICATE_API_TOKEN=
REPLICATE_WEBHOOK_SECRET=
REPLICATE_USERNAME=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional aliases read by lib/supabase-vault.js when NEXT_PUBLIC_* not set
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional override for magic-link redirect target (overrides Origin header)
APP_URL=
SECURITY_HEADERS_ENABLED=true
MAX_UPLOAD_MB=10
MAX_AVATAR_MB=5
RATE_LIMIT_REDIS_URL=
VEO_PROMPT_ENHANCER_KEY=your-anthropic-api-key-for-veo-prompt-enhancement
